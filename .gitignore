# Unreal Engine generated/derived directories — never commit
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Plugins/*/Binaries/
Plugins/*/Intermediate/

# Build/ is mostly engine-generated stable assets we WANT to ship (the
# entitlements + Info.plist template under Build/Mac/Resources/, the
# post-stage helper script under Build/Mac/Scripts/). Ignore only the
# genuinely-noisy bits.
Build/Mac/*.PackageVersionCounter
Build/Mac/FileOpenOrder/

# Belt-and-suspenders: explicitly exclude API keys (Anthropic + OpenAI)
# and the entire secrets folder regardless of where it ends up.
Saved/AnthropicAPIKey.txt
**/AnthropicAPIKey.txt
**/OpenAIAPIKey.txt
**/Secrets/
*.apikey

# Claude Code internal state (scheduled tasks, session locks, etc.)
.claude/

# IDE/project files generated by the engine
.vs/
.vscode/
.idea/
*.xcodeproj/
*.xcworkspace/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Compiled binaries
*.dylib
*.dll
*.so
*.app/
*.dSYM/
*.exe
*.o
*.obj
*.pch
*.gch
*.lib
*.a

# Built level data (regenerated by the editor)
*_BuiltData.uasset

# macOS
.DS_Store
._*

# Logs / crash dumps
*.log

# Editor/IDE search-exclusion files
.ignore

# Whitelist files we DO want to keep that the rules above might catch
!Build/**/PakBlacklist*.txt
!Build/**/*.ico
